# Modelo de variáveis de ambiente. Copie para .env e ajuste os valores:
#   PowerShell:  Copy-Item .env.example .env
#   Linux/Mac:   cp .env.example .env
#
# Em PRODUÇÃO não use este arquivo: defina as variáveis no ambiente do servidor
# (ou em um secret manager). DB_PASSWORD e ADMIN_SENHA são obrigatórias.

# --- Banco de dados ---
DB_URL=jdbc:postgresql://localhost:5432/idtnpr
DB_USER=idtnpr
DB_PASSWORD=troque-esta-senha-de-banco

# --- Admin inicial (criado na primeira execução pelo DataSeeder) ---
ADMIN_EMAIL=admin@idtnpr.org.br
ADMIN_SENHA=defina-uma-senha-forte

# --- Segurança / aplicação ---
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
JWT_EXP_MINUTES=480
STORAGE_DIR=./uploads

# --- Perfil ativo (dev | prod) ---
SPRING_PROFILES_ACTIVE=dev
