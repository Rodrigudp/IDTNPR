# =====================================================================
# Modelo de configuração. COPIE este arquivo para ".env" e ajuste:
#   Windows:  Copy-Item .env.example .env
#   Linux:    cp .env.example .env
#
# O arquivo ".env" guarda as senhas e NÃO deve ir para o Git.
# Na Locaweb, os dados do banco aparecem no painel de controle.
# =====================================================================

# --- Banco de dados MySQL (dados que a Locaweb fornece) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=idtnpr
DB_USER=idtnpr
DB_PASSWORD=troque-esta-senha-de-banco

# --- Usuário admin inicial (criado pelo instalar.php) ---
ADMIN_NOME=Administrador IDTNPR
ADMIN_EMAIL=admin@idtnpr.org.br
ADMIN_SENHA=defina-uma-senha-forte

# --- Segurança ---
# Senha secreta usada para assinar o token de login. Use um texto longo
# e aleatório (ex.: 40+ caracteres). NUNCA compartilhe.
JWT_SECRET=troque-por-um-texto-longo-e-aleatorio
# Quanto tempo o login dura, em minutos (480 = 8 horas).
JWT_EXP_MINUTES=480

# --- Front-end liberado no CORS (endereços do site, separados por vírgula) ---
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# --- Pasta onde os arquivos enviados são guardados ---
STORAGE_DIR=./uploads
